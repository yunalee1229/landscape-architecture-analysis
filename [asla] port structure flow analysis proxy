# --------------------------------------------------
# 0. library
# --------------------------------------------------
import numpy as np
import rasterio
from rasterio.warp import reproject, Resampling
import matplotlib.pyplot as plt
from scipy.ndimage import distance_transform_edt, gaussian_filter

# --------------------------------------------------
# 1. path
# --------------------------------------------------
SEA_PATH = "C:/Users/twins/OneDrive/문서/바탕 화면/26-1/asla/6p/ocean2.tif"
LAND_PATH = "C:/Users/twins/OneDrive/문서/바탕 화면/26-1/asla/6p/land.tif"

# 새로 만들어야 하는 tif
BASIN_PATH = "C:/Users/twins/OneDrive/문서/바탕 화면/26-1/asla/6p/port2.tif"
STRUCTURE_PATH = "C:/Users/twins/OneDrive/문서/바탕 화면/26-1/asla/6p/structure.tif"

OUT_PREFIX = "C:/Users/twins/OneDrive/문서/바탕 화면/26-1/asla/6p/flow_result_3"

# --------------------------------------------------
# 2. reference raster load
# --------------------------------------------------
with rasterio.open(SEA_PATH) as src:
    sea = src.read(1).astype(np.float32)
    profile = src.profile.copy()

sea = np.where(sea > 0, 1, 0).astype(np.uint8)

# --------------------------------------------------
# 3. read and match raster
# --------------------------------------------------
def read_match(path, ref_profile):
    with rasterio.open(path) as src:
        data = np.zeros(
            (ref_profile["height"], ref_profile["width"]),
            dtype=np.float32
        )

        reproject(
            source=rasterio.band(src, 1),
            destination=data,
            src_transform=src.transform,
            src_crs=src.crs,
            dst_transform=ref_profile["transform"],
            dst_crs=ref_profile["crs"],
            resampling=Resampling.nearest
        )

    return np.where(data > 0, 1, 0).astype(np.uint8)

land = read_match(LAND_PATH, profile)
basin = read_match(BASIN_PATH, profile)
structure = read_match(STRUCTURE_PATH, profile)

# --------------------------------------------------
# 4. mask setting
# --------------------------------------------------
land_block = land == 1
basin_area = basin == 1
structure_area = structure == 1

# sea는 항만 내부 포함한 전체 바다
# basin은 분석 기준 영역
# structure는 핑크색 설치 영역만
analysis_water = (sea == 1) & (~land_block)

ny, nx = sea.shape

print("===== Mask Check =====")
print(f"Sea cells: {np.sum(sea == 1)}")
print(f"Land cells: {np.sum(land_block)}")
print(f"Basin cells: {np.sum(basin_area)}")
print(f"Structure cells: {np.sum(structure_area)}")
print(f"Analysis water cells: {np.sum(analysis_water)}")
print(f"Structure inside analysis water: {np.sum(structure_area & analysis_water)}")
print(f"Basin inside analysis water: {np.sum(basin_area & analysis_water)}")

# --------------------------------------------------
# 5. base current field
# --------------------------------------------------
u_base = np.ones((ny, nx), dtype=np.float32)
v_base = np.zeros((ny, nx), dtype=np.float32)

u_base[~analysis_water] = 0
v_base[~analysis_water] = 0

# --------------------------------------------------
# 6. coastline / narrow water damping
# --------------------------------------------------
dist_to_edge = distance_transform_edt(analysis_water)

coast_decay = 35
coast_factor = 1 - np.exp(-dist_to_edge / coast_decay)
coast_factor = np.clip(coast_factor, 0.25, 1.0)

u_base *= coast_factor
v_base *= coast_factor

# --------------------------------------------------
# 7. structure influence model
# --------------------------------------------------
# 이제 항만 전체가 아니라 structure_area만 영향원으로 봄
dist_to_structure = distance_transform_edt(~structure_area)

structure_decay = 25
structure_influence = np.exp(-dist_to_structure / structure_decay)
structure_influence[~analysis_water] = 0
structure_influence = gaussian_filter(structure_influence, sigma=2)
structure_influence = np.clip(structure_influence, 0, 1)

# --------------------------------------------------
# 8. filled / reclaimed structure scenario
# --------------------------------------------------
u_fill = u_base.copy()
v_fill = v_base.copy()

# 매립식: 핑크 구조물 영역만 완전 차단
u_fill[structure_area] = 0
v_fill[structure_area] = 0

filled_blocking_strength = 0.75

u_fill *= (1 - filled_blocking_strength * structure_influence)
v_fill *= (1 - filled_blocking_strength * structure_influence)

u_fill[~analysis_water] = 0
v_fill[~analysis_water] = 0

# --------------------------------------------------
# 9. pier structure scenario
# --------------------------------------------------
u_pier = u_base.copy()
v_pier = v_base.copy()

# 잔교식: 핑크 구조물 영역에서 일부 흐름 허용
pier_permeability = 0.45

u_pier[structure_area] *= pier_permeability
v_pier[structure_area] *= pier_permeability

pier_blocking_strength = 0.30

u_pier *= (1 - pier_blocking_strength * structure_influence)
v_pier *= (1 - pier_blocking_strength * structure_influence)

u_pier[~analysis_water] = 0
v_pier[~analysis_water] = 0

# --------------------------------------------------
# 10. speed / improvement
# --------------------------------------------------
speed_fill = np.sqrt(u_fill**2 + v_fill**2)
speed_pier = np.sqrt(u_pier**2 + v_pier**2)

flow_improvement = speed_pier - speed_fill
flow_improvement[~analysis_water] = np.nan

# --------------------------------------------------
# 11. impact zone setting
# --------------------------------------------------
# 영향권은 structure 주변 + basin 내부를 함께 고려
impact_radius = 80

impact_from_structure = dist_to_structure <= impact_radius
impact_zone = (impact_from_structure | basin_area) & analysis_water

dead_threshold = 0.25

dead_fill = (speed_fill < dead_threshold) & impact_zone
dead_pier = (speed_pier < dead_threshold) & impact_zone

dead_fill_area = np.sum(dead_fill)
dead_pier_area = np.sum(dead_pier)

mean_fill = np.nanmean(speed_fill[impact_zone])
mean_pier = np.nanmean(speed_pier[impact_zone])

if mean_fill > 0:
    improve_rate = (mean_pier - mean_fill) / mean_fill * 100
else:
    improve_rate = np.nan

if dead_fill_area > 0:
    reduction = (dead_fill_area - dead_pier_area) / dead_fill_area * 100
else:
    reduction = np.nan

# --------------------------------------------------
# 12. visualization
# --------------------------------------------------
x = np.arange(nx)
y = np.arange(ny)

# 화살표 촘촘하게
step = max(1, nx // 250)

fig, ax = plt.subplots(2, 3, figsize=(18, 11))

# base mask
base_map = np.full((ny, nx), np.nan)
base_map[analysis_water] = 1
base_map[land_block] = 2
base_map[basin_area] = 3
base_map[structure_area] = 4

ax[0, 0].imshow(base_map)
ax[0, 0].set_title("Base Mask\nWater / Land / Basin / Structure")

# filled flow
ax[0, 1].imshow(speed_fill, alpha=0.85)
ax[0, 1].contour(impact_zone, levels=[0.5], linewidths=1.2)
ax[0, 1].contour(structure_area, levels=[0.5], linewidths=1.3)
ax[0, 1].streamplot(
    x[::step], y[::step],
    u_fill[::step, ::step],
    v_fill[::step, ::step],
    density=2.0,
    linewidth=0.6,
    arrowsize=0.7
)
ax[0, 1].set_title("Reclaimed Structure Flow\nStructure Area Blocked")

# pier flow
ax[0, 2].imshow(speed_pier, alpha=0.85)
ax[0, 2].contour(impact_zone, levels=[0.5], linewidths=1.2)
ax[0, 2].contour(structure_area, levels=[0.5], linewidths=1.3)
ax[0, 2].streamplot(
    x[::step], y[::step],
    u_pier[::step, ::step],
    v_pier[::step, ::step],
    density=2.2,
    linewidth=0.6,
    arrowsize=0.7
)
ax[0, 2].set_title("Pier Structure Flow\nStructure Area Permeable")

# dead zone filled
ax[1, 0].imshow(dead_fill)
ax[1, 0].contour(structure_area, levels=[0.5], linewidths=1.0)
ax[1, 0].set_title(f"Dead Zone in Impact Zone - Reclaimed\nArea: {dead_fill_area} cells")

# dead zone pier
ax[1, 1].imshow(dead_pier)
ax[1, 1].contour(structure_area, levels=[0.5], linewidths=1.0)
ax[1, 1].set_title(f"Dead Zone in Impact Zone - Pier\nArea: {dead_pier_area} cells")

# improvement
im = ax[1, 2].imshow(flow_improvement)
ax[1, 2].contour(impact_zone, levels=[0.5], linewidths=1.2)
ax[1, 2].contour(structure_area, levels=[0.5], linewidths=1.3)
ax[1, 2].set_title("Flow Improvement\nPier - Reclaimed")
plt.colorbar(im, ax=ax[1, 2], fraction=0.046)

for a in ax.flat:
    a.axis("off")

plt.tight_layout()
plt.savefig(OUT_PREFIX + "_comparison.png", dpi=300)
plt.show()

# --------------------------------------------------
# 13. save raster outputs
# --------------------------------------------------
out_profile = profile.copy()
out_profile.update(dtype=rasterio.float32, count=1, nodata=-9999)

def save_tif(path, arr):
    arr_out = arr.astype(np.float32).copy()
    arr_out[~analysis_water] = -9999
    with rasterio.open(path, "w", **out_profile) as dst:
        dst.write(arr_out, 1)

save_tif(OUT_PREFIX + "_speed_reclaimed.tif", speed_fill)
save_tif(OUT_PREFIX + "_speed_pier.tif", speed_pier)
save_tif(OUT_PREFIX + "_flow_improvement.tif", flow_improvement)
save_tif(OUT_PREFIX + "_dead_reclaimed_impactzone.tif", dead_fill.astype(np.float32))
save_tif(OUT_PREFIX + "_dead_pier_impactzone.tif", dead_pier.astype(np.float32))
save_tif(OUT_PREFIX + "_impact_zone.tif", impact_zone.astype(np.float32))
save_tif(OUT_PREFIX + "_structure_influence.tif", structure_influence.astype(np.float32))

# --------------------------------------------------
# 14. result summary
# --------------------------------------------------
print("===== Flow Comparison Result =====")
print(f"Analysis water cells: {np.sum(analysis_water)}")
print(f"Basin cells: {np.sum(basin_area)}")
print(f"Structure cells: {np.sum(structure_area)}")
print(f"Structure cells included in analysis: {np.sum(structure_area & analysis_water)}")
print(f"Impact zone cells: {np.sum(impact_zone)}")
print(f"Dead zone in impact zone - Reclaimed: {dead_fill_area} cells")
print(f"Dead zone in impact zone - Pier     : {dead_pier_area} cells")
print(f"Dead zone reduction in impact zone  : {reduction:.2f}%")
print(f"Mean speed in impact zone - Reclaimed: {mean_fill:.3f}")
print(f"Mean speed in impact zone - Pier     : {mean_pier:.3f}")
print(f"Mean speed improvement in impact zone: {improve_rate:.2f}%")

# --------------------------------------------------
# 15. advanced indicators
# --------------------------------------------------
target_zone = impact_zone

mean_speed_fill = np.nanmean(speed_fill[target_zone])
mean_speed_pier = np.nanmean(speed_pier[target_zone])

speed_increase_rate = (
    (mean_speed_pier - mean_speed_fill) / mean_speed_fill * 100
    if mean_speed_fill > 0 else np.nan
)

recovery_threshold = 0.10
flow_recovery = (flow_improvement > recovery_threshold) & target_zone

recovery_cells = np.sum(flow_recovery)
target_cells = np.sum(target_zone)

recovery_area_rate = recovery_cells / target_cells * 100 if target_cells > 0 else np.nan

epsilon = 0.05

residence_fill = 1 / (speed_fill + epsilon)
residence_pier = 1 / (speed_pier + epsilon)

residence_fill = np.clip(residence_fill, 0, 20)
residence_pier = np.clip(residence_pier, 0, 20)

mean_residence_fill = np.nanmean(residence_fill[target_zone])
mean_residence_pier = np.nanmean(residence_pier[target_zone])

residence_reduction_rate = (
    (mean_residence_fill - mean_residence_pier) / mean_residence_fill * 100
    if mean_residence_fill > 0 else np.nan
)

risk_fill = residence_fill / np.nanmax(residence_fill[target_zone])
risk_pier = residence_pier / np.nanmax(residence_fill[target_zone])

mean_risk_fill = np.nanmean(risk_fill[target_zone])
mean_risk_pier = np.nanmean(risk_pier[target_zone])

water_quality_risk_reduction = (
    (mean_risk_fill - mean_risk_pier) / mean_risk_fill * 100
    if mean_risk_fill > 0 else np.nan
)

print("===== Advanced Hydrodynamic Proxy Indicators =====")
print(f"Mean speed - Reclaimed: {mean_speed_fill:.4f}")
print(f"Mean speed - Pier     : {mean_speed_pier:.4f}")
print(f"Mean speed increase   : {speed_increase_rate:.2f}%")
print(f"Flow recovery cells   : {recovery_cells}")
print(f"Flow recovery area rate: {recovery_area_rate:.2f}%")
print(f"Residence time proxy - Reclaimed: {mean_residence_fill:.4f}")
print(f"Residence time proxy - Pier     : {mean_residence_pier:.4f}")
print(f"Residence time reduction        : {residence_reduction_rate:.2f}%")
print(f"Water stagnation risk - Reclaimed: {mean_risk_fill:.4f}")
print(f"Water stagnation risk - Pier     : {mean_risk_pier:.4f}")
print(f"Water stagnation risk reduction  : {water_quality_risk_reduction:.2f}%")
